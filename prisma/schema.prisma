enum ContactImportJobStatus {
  DRAFT
  PREVIEWED
  IMPORTING
  COMPLETED
  FAILED
}

enum ContactImportRowStatus {
  READY
  SKIPPED
  IMPORTED
  FAILED
}

enum ContactImportDuplicateStrategy {
  UPDATE_EXISTING
  SKIP_EXISTING
}

model ContactImportJob {
  id String @id @default(cuid())

  companyId   String
  actorUserId String?

  status            ContactImportJobStatus         @default(DRAFT)
  duplicateStrategy ContactImportDuplicateStrategy @default(UPDATE_EXISTING)

  fileName     String?
  totalRows    Int     @default(0)
  readyRows    Int     @default(0)
  skippedRows  Int     @default(0)
  importedRows Int     @default(0)
  failedRows   Int     @default(0)

  fieldMapping   Json?
  consentMapping Json?
  previewSummary Json?
  errorMessage   String?

  startedAt   DateTime?
  completedAt DateTime?
  failedAt    DateTime?

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actorUser User?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  rows ContactImportRow[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([actorUserId])
  @@index([status])
  @@index([createdAt])
}

model ContactImportRow {
  id String @id @default(cuid())

  companyId String
  jobId     String

  rowNumber Int
  status    ContactImportRowStatus @default(READY)

  raw        Json?
  normalized Json?

  phone String?
  email String?
  name  String?

  contactId String?

  errorMessage  String?
  consentStatus String?
  consentProof  String?

  company Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job     ContactImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  contact Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([jobId])
  @@index([contactId])
  @@index([status])
  @@index([phone])
  @@index([email])
  @@index([rowNumber])
}

