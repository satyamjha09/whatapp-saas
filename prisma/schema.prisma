 @@index([checkoutId])
 @@index([requestedByUserId])
 @@index([status])
 @@index([type])
 @@index([razorpayPaymentId])
 @@index([razorpayRefundId])
 @@index([createdAt])
 @@index([lastReconciliationAt])
 @@index([webhookProcessedAt])
}

model BillingCreditNote {
