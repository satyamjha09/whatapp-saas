  ignoredCampaignFailureInsights      CampaignFailureInsight[]           @relation("IgnoredCampaignFailureInsights")
  retriedCampaignFailureInsights      CampaignFailureInsight[]           @relation("RetriedCampaignFailureInsights")
  updatedCampaignThroughputPolicies   CampaignThroughputPolicy[]
