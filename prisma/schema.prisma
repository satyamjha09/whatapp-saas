model PrivacyRequest {
  id String @id @default(cuid())

  companyId         String
  contactId         String?
  requestedByUserId String?

  type   PrivacyRequestType
  status PrivacyRequestStatus @default(PENDING)
  source PrivacyRequestSource @default(DASHBOARD)

  requesterEmail   String?
  reason           String?
  confirmationText String?

  exportFilePath  String?
  exportFileName  String?
  exportExpiresAt DateTime?

  processedAt   DateTime?
  failedAt      DateTime?
  failureReason String?

  metadata Json?

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  requestedBy User?    @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([contactId])
  @@index([requestedByUserId])
  @@index([type])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@index([exportExpiresAt])
}

model PublicPrivacyVerification {
  id String @id @default(cuid())

  companyId String?

  email     String
  emailHash String

  phoneNumber String?
  countryCode String?

  intent PublicPrivacyRequestIntent

  tokenHash String
  status    PublicPrivacyVerificationStatus @default(PENDING)

  requesterIp String?
  userAgent   String?

  reason String?

  privacyRequestId String?

  expiresAt DateTime
  usedAt    DateTime?

  failureReason String?
  metadata      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([emailHash])
  @@index([tokenHash])
  @@index([status])
  @@index([intent])
  @@index([expiresAt])
  @@index([createdAt])
}

model DataRetentionPolicy {
  id String @id @default(cuid())

  companyId String?

  entityType DataRetentionEntityType
  status     DataRetentionPolicyStatus @default(ACTIVE)

  retentionDays Int
  action        DataRetentionAction @default(DELETE)

  description String?

  lastRunAt DateTime?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, entityType])
  @@index([companyId])
  @@index([entityType])
  @@index([status])
  @@index([lastRunAt])
}

model DataRetentionRun {
  id String @id @default(cuid())

  status DataRetentionRunStatus @default(RUNNING)

  dryRun Boolean @default(true)

  checkedCount Int @default(0)
  deletedCount Int @default(0)
  skippedCount Int @default(0)
  failedCount  Int @default(0)

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  errorMessage String?

  items DataRetentionRunItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([dryRun])
  @@index([startedAt])
}

model DataRetentionRunItem {
  id String @id @default(cuid())

  runId String

  companyId String?
  policyId  String?

  entityType DataRetentionEntityType
  action     DataRetentionAction

  checkedCount Int @default(0)
  deletedCount Int @default(0)
  skippedCount Int @default(0)
  failedCount  Int @default(0)

  cutoffAt DateTime

  errorMessage String?
  metadata     Json?

  run DataRetentionRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([runId])
  @@index([companyId])
  @@index([policyId])
  @@index([entityType])
  @@index([createdAt])
}

model LegalHold {
  id String @id @default(cuid())

  companyId String?

  entityType LegalHoldEntityType
