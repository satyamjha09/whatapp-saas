  whatsAppEmbeddedSignupEvents      WhatsAppEmbeddedSignupEvent[]
  whatsAppFlows                     WhatsAppFlow[]
  whatsAppFlowInteractions          WhatsAppFlowInteraction[]
  whatsAppFlowResponses             WhatsAppFlowResponse[]
  chatbots                          Chatbot[]
  chatbotVersions                   ChatbotVersion[]
  chatbotNodes                      ChatbotNode[]
  chatbotEdges                      ChatbotEdge[]
  chatbotTriggers                   ChatbotTrigger[]
  chatbotSessions                   ChatbotSession[]
  chatbotSessionEvents              ChatbotSessionEvent[]
  contactImportJobs                 ContactImportJob[]
  contactImportRows                 ContactImportRow[]
  templates                         Template[]
  templateLifecycleEvents           TemplateLifecycleEvent[]
  templateMediaAssets               TemplateMediaAsset[]
  contacts                          Contact[]
  messages                          Message[]
  messageEvents                     MessageEvent[]
  webhookEvents                     WebhookEvent[]
  resolvedUnmappedWebhookEvents     UnmappedWebhookEvent[]
  campaigns                         Campaign[]
  broadcastCampaignDrafts           BroadcastCampaignDraft[]
  campaignContacts                  CampaignContact[]
  wallet                            Wallet?
  leadScoringConfig                 LeadScoringConfig?
  walletTransactions                WalletTransaction[]
  invites                           CompanyInvite[]
  auditLogs                         AuditLog[]
  inboxNotes                        InboxNote[]
  inboxNoteMentions                 InboxNoteMention[]
  inboxConversationFollowers        InboxConversationFollower[]
  inboxQueues                       InboxQueue[]
  inboxQueueMembers                 InboxQueueMember[]
  inboxAgentProfiles                InboxAgentProfile[]
  inboxAgentMetricDaily             InboxAgentMetricDaily[]
  inboxSkills                       InboxSkill[]
  inboxAgentSkills                  InboxAgentSkill[]
  inboxQueueRequiredSkills          InboxQueueRequiredSkill[]
  inboxConversationAssignments      InboxConversationAssignment[]
  inboxRoutingRules                 InboxRoutingRule[]
  inboxReplyApprovals               InboxReplyApproval[]
  inboxBusinessHours                InboxBusinessHours[]
  inboxHolidays                     InboxHoliday[]
  inboxSlaPolicies                  InboxSlaPolicy[]
  inboxSlaEvents                    InboxSlaEvent[]
  inboxEscalationRules              InboxEscalationRule[]
  inboxCsatSurveys                  InboxCsatSurvey[]
  inboxConversationSummaries        InboxConversationSummary[]
  inboxAiSuggestions                InboxAiSuggestion[]
  inboxMessageTranslations          InboxMessageTranslation[]
  inboxTags                         InboxTag[]
  contactInboxTags                  ContactInboxTag[]
