model User {
  id          String  @id @default(cuid())
  clerkUserId String  @unique
  email       String  @unique
  name        String?
  imageUrl    String?

  companies                          CompanyUser[]
  assignedContacts                   Contact[]                          @relation("ContactAssignee")
  inboxNotes                         InboxNote[]                        @relation("InboxNoteAuthor")
  contactActivities                  ContactActivity[]
  inboxSavedViews                    InboxSavedView[]
  createdQuickReplies                QuickReply[]                       @relation("QuickReplyCreator")
  sentCompanyInvites                 CompanyInvite[]                    @relation("SentCompanyInvites")
  acceptedCompanyInvites             CompanyInvite[]                    @relation("AcceptedCompanyInvites")
  auditLogs                          AuditLog[]
  createdApiKeys                     ApiKey[]
  createdBulkMessageBatches          BulkMessageBatch[]
  companyNotificationRecipients      CompanyNotificationRecipient[]
  companyNotificationPreferences     CompanyNotificationPreference[]
  companyNotificationEmailDeliveries CompanyNotificationEmailDelivery[]
  privacyRequests                    PrivacyRequest[]
  contactConsentEvents               ContactConsentEvent[]
  complianceEvidenceExports          ComplianceEvidenceExport[]
  trustDocumentAcceptances           TrustDocumentAcceptance[]
  accessRoleAssignments              CompanyAccessRoleAssignment[]
  createdEntitlementOverrides        CompanyEntitlementOverride[]
  entitlementCheckLogs               FeatureEntitlementCheckLog[]
  requestedPlanCheckouts             PlanCheckout[]
  companyPlanChanges                 CompanyPlanChange[]
  billingInvoices                    BillingInvoice[]
  requestedScheduledPlanChanges      ScheduledPlanChange[]
  manualReviewedPlanCheckouts        PlanCheckout[]                     @relation("ManualReviewedPlanCheckouts")
  requestedBillingRefunds BillingRefund[]
  updatedBillingProfiles CompanyBillingProfile[] @relation("BillingProfileUpdatedBy")
  billingProfileUpdateEvents BillingProfileUpdateEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id   String @id @default(cuid())
  name String

  metaPaymentMethodAdded         Boolean   @default(false)
  metaBusinessVerificationStatus String    @default("NOT_STARTED")
  productionChecklistNotes       String?
  productionChecklistUpdatedAt   DateTime?

  billingPlan            BillingPlan        @default(FREE)
  subscriptionStatus     SubscriptionStatus @default(TRIALING)
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  monthlyMessageLimit    Int                @default(100)
  cancelAtPeriodEnd      Boolean            @default(false)
  subscriptionCanceledAt DateTime?

  users                       CompanyUser[]
  whatsAppAccounts            WhatsAppAccount[]
  whatsAppPhoneNumbers        WhatsAppPhoneNumber[]
  templates                   Template[]
  contacts                    Contact[]
  messages                    Message[]
  messageEvents               MessageEvent[]
  webhookEvents               WebhookEvent[]
  campaigns                   Campaign[]
  campaignContacts            CampaignContact[]
  wallet                      Wallet?
  walletTransactions          WalletTransaction[]
  invites                     CompanyInvite[]
  auditLogs                   AuditLog[]
  inboxNotes                  InboxNote[]
  inboxTags                   InboxTag[]
  contactInboxTags            ContactInboxTag[]
  contactActivities           ContactActivity[]
  inboxSavedViews             InboxSavedView[]
  campaignAnalyticsSnapshots  CampaignAnalyticsSnapshot[]
  campaignReplyAttributions   CampaignReplyAttribution[]
  quickReplies                QuickReply[]
  apiKeys                     ApiKey[]
  developerWebhookEndpoints   DeveloperWebhookEndpoint[]
  developerWebhookDeliveries  DeveloperWebhookDelivery[]
  developerWebhookOutbox      DeveloperWebhookOutbox[]
  bulkMessageBatches          BulkMessageBatch[]
  contactGroups               ContactGroup[]
  creditPurchases             CreditPurchase[]
  subscriptionPayments        SubscriptionPayment[]
  razorpayWebhookEvents       RazorpayWebhookEvent[]
  maintenanceJobRuns          MaintenanceJobRun[]
  developerApiUsage           DeveloperApiUsage[]
  developerApiRequestLogs     DeveloperApiRequestLog[]
  publicApiIdempotencyRecords PublicApiIdempotencyRecord[]
  privacyRequests             PrivacyRequest[]
  contactConsentEvents        ContactConsentEvent[]
  complianceEvidenceExports   ComplianceEvidenceExport[]
  trustDocumentAcceptances    TrustDocumentAcceptance[]
  accessRoles                 CompanyAccessRole[]
  accessRoleAssignments       CompanyAccessRoleAssignment[]
  entitlementOverrides        CompanyEntitlementOverride[]
  entitlementCheckLogs        FeatureEntitlementCheckLog[]
  featureUsageCounters        FeatureUsageCounter[]
  featureUsageEvents          FeatureUsageEvent[]
  usageQuotaAlerts            UsageQuotaAlert[]
  planCheckouts               PlanCheckout[]
  planChanges                 CompanyPlanChange[]
  billingInvoices             BillingInvoice[]
  subscriptionRenewalEvents   SubscriptionRenewalEvent[]
  scheduledPlanChanges        ScheduledPlanChange[]
  planCheckoutReconciliationEvents PlanCheckoutReconciliationEvent[]
  billingRefunds     BillingRefund[]
  billingCreditNotes BillingCreditNote[]
  billingRefundReconciliationEvents BillingRefundReconciliationEvent[]
  billingProfile CompanyBillingProfile?
  billingProfileUpdateEvents BillingProfileUpdateEvent[]
  billingDocumentEmailDeliveries BillingDocumentEmailDelivery[]
  billingDocumentPdfRenders BillingDocumentPdfRender[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyUser {
  id String @id @default(cuid())

  userId    String
  companyId String
  role      CompanyRole @default(MEMBER)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, companyId])
}

model CompanyNotification {
  id             String                      @id @default(cuid())
  companyId      String
  type           CompanyNotificationType
  severity       CompanyNotificationSeverity @default(INFO)
  status         CompanyNotificationStatus   @default(UNREAD)
  title          String
  message        String
  actionHref     String?
  idempotencyKey String?
  metadata       Json?
  readAt         DateTime?
  archivedAt     DateTime?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  recipients      CompanyNotificationRecipient[]
  emailDeliveries CompanyNotificationEmailDelivery[]

  @@unique([companyId, idempotencyKey])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, type])
  @@index([createdAt])
}

model CompanyNotificationRecipient {
  id             String                    @id @default(cuid())
  notificationId String
  userId         String
  status         CompanyNotificationStatus @default(UNREAD)
  readAt         DateTime?
  archivedAt     DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  notification CompanyNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([notificationId])
  @@index([userId])
  @@index([userId, status])
}

model CompanyNotificationPreference {
  id                   String                      @id @default(cuid())
  companyId            String
  userId               String
  type                 CompanyNotificationType
  inAppEnabled         Boolean                     @default(true)
  minimumSeverity      CompanyNotificationSeverity @default(INFO)
  emailEnabled         Boolean                     @default(false)
  emailMinimumSeverity CompanyNotificationSeverity @default(ERROR)
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, type])
  @@index([companyId])
  @@index([userId])
}

model CompanyNotificationEmailDelivery {
  id             String                                 @id @default(cuid())
  companyId      String
  notificationId String
  userId         String
  toEmail        String
  subject        String
  actionUrl      String?
  status         CompanyNotificationEmailDeliveryStatus @default(PENDING)
  attempts       Int                                    @default(0)
  lastError      String?
  sentAt         DateTime?
  skippedAt      DateTime?
  createdAt      DateTime                               @default(now())
  updatedAt      DateTime                               @updatedAt

  notification CompanyNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([companyId])
  @@index([notificationId])
  @@index([userId])
  @@index([status])
}

model WhatsAppAccount {
  id        String @id @default(cuid())
  companyId String

  wabaId                 String?               @unique
  businessName           String?
  accessToken            String?
  accessTokenKeyId       String?
  accessTokenEncryptedAt DateTime?
  status                 WhatsAppAccountStatus @default(PENDING)

  company      Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  phoneNumbers WhatsAppPhoneNumber[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([accessTokenKeyId])
}

model WhatsAppPhoneNumber {
  id                String @id @default(cuid())
  companyId         String
  whatsAppAccountId String

  phoneNumberId      String? @unique
  displayPhoneNumber String?
  verifiedName       String?
  qualityRating      String?

  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  whatsAppAccount WhatsAppAccount @relation(fields: [whatsAppAccountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([whatsAppAccountId])
}

model Template {
  id        String @id @default(cuid())
  companyId String

  name     String
  language String
  category TemplateCategory
  status   TemplateStatus   @default(DRAFT)

  body       String
  variables  String[]
  components Json?

  metaTemplateId String?

  company            Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messages           Message[]
  campaigns          Campaign[]
  bulkMessageBatches BulkMessageBatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name, language])
  @@index([companyId])
}

model Contact {
  id               String  @id @default(cuid())
  companyId        String
  assignedToUserId String?

  name                   String?
  email                  String?
  companyName            String?
  phoneNumber            String
  countryCode            String                @default("91")
  source                 String                @default("MANUAL")
  externalCustomerId     String?
  lifecycleStage         String                @default("LEAD")
  lastSeenAt             DateTime?
  lastRepliedAt          DateTime?
  lastProfileUpdatedAt   DateTime?
  isBlocked              Boolean               @default(false)
  blockedAt              DateTime?
  optedOutAt             DateTime?
  optOutReason           String?
  optOutSource           String?
  marketingConsentStatus ContactConsentStatus  @default(UNKNOWN)
  marketingConsentAt     DateTime?
  marketingConsentSource ContactConsentSource?
  utilityConsentStatus   ContactConsentStatus  @default(UNKNOWN)
  utilityConsentAt       DateTime?
  utilityConsentSource   ContactConsentSource?

  inboxStatus                InboxConversationStatus @default(OPEN)
  inboxClosedAt              DateTime?
  inboxPriority              InboxPriority           @default(NORMAL)
  snoozedUntil               DateTime?
  inboxSlaDueAt              DateTime?
  inboxLastCustomerMessageAt DateTime?
  inboxSlaBreachedAt         DateTime?
  inboxSlaEscalationCount    Int                     @default(0)

  company                   Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedTo                User?                      @relation("ContactAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  messages                  Message[]
  inboxNotes                InboxNote[]
  inboxTags                 ContactInboxTag[]
  activities                ContactActivity[]
  campaignContacts          CampaignContact[]
  campaignReplyAttributions CampaignReplyAttribution[]
  contactGroupMembers       ContactGroupMember[]
  privacyRequests           PrivacyRequest[]
  consentEvents             ContactConsentEvent[]
  complianceEvidenceExports ComplianceEvidenceExport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, phoneNumber])
  @@index([companyId])
  @@index([companyId, marketingConsentStatus])
  @@index([companyId, utilityConsentStatus])
  @@index([assignedToUserId])
  @@index([companyId, inboxStatus])
  @@index([companyId, inboxPriority])
  @@index([companyId, snoozedUntil])
  @@index([companyId, inboxSlaDueAt])
  @@index([companyId, inboxStatus, inboxSlaDueAt])
  @@index([companyId, inboxSlaBreachedAt])
  @@index([companyId, inboxStatus, inboxSlaDueAt, inboxSlaBreachedAt])
  @@index([companyId, optedOutAt])
  @@index([companyId, lifecycleStage])
  @@index([companyId, externalCustomerId])
  @@index([marketingConsentAt])
  @@index([lastSeenAt])
  @@index([lastRepliedAt])
}

model ContactConsentEvent {
  id String @id @default(cuid())

  companyId String
  contactId String

  type   ContactConsentType
  status ContactConsentStatus
  source ContactConsentSource

  actorUserId String?

  evidenceText String?
  evidenceUrl  String?
  ipAddress    String?
  userAgent    String?

  metadata Json?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  actor   User?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([contactId])
  @@index([actorUserId])
  @@index([type])
  @@index([status])
  @@index([source])
  @@index([createdAt])
}

model PrivacyRequest {
  id String @id @default(cuid())

  companyId         String
  contactId         String?
  requestedByUserId String?

  type   PrivacyRequestType
  status PrivacyRequestStatus @default(PENDING)
  source PrivacyRequestSource @default(DASHBOARD)

  requesterEmail   String?
  reason           String?
  confirmationText String?

  exportFilePath  String?
  exportFileName  String?
  exportExpiresAt DateTime?

  processedAt   DateTime?
  failedAt      DateTime?
  failureReason String?

