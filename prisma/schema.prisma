enum BillingRefundStatus {
 REQUESTED
 PROCESSING
 PROCESSED
 FAILED
 CANCELLED
}

enum BillingRefundType {
 FULL
 PARTIAL
}

enum BillingRefundSource {
 ADMIN
 SYSTEM
}

enum BillingCreditNoteStatus {
 ISSUED
 VOID
}

model BillingRefund {
 id String @id @default(cuid())

 companyId String
 invoiceId String?
 checkoutId String?

 requestedByUserId String?

 type   BillingRefundType
 source BillingRefundSource @default(ADMIN)
 status BillingRefundStatus @default(REQUESTED)

 amountPaise Int
 currency    String @default("INR")

 reason String?
 confirmationText String?

 razorpayPaymentId String?
 razorpayRefundId  String?
 razorpayStatus    String?

 processedAt DateTime?
 failedAt    DateTime?
 failureReason String?

