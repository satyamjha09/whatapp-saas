model User {
  id          String  @id @default(cuid())
  clerkUserId String  @unique
  email       String  @unique
  name        String?
  mobile      String?
  imageUrl    String?

  platformRole          PlatformRole @default(NONE)
  platformAccessEnabled Boolean      @default(false)

  companies                           CompanyUser[]
  // Tenant-scoped records below must not be loaded via User include/select.
  // Query them with both companyId and userId, preferably through
