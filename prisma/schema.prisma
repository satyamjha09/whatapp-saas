  updatedAt DateTime @updatedAt

  @@unique([companyId, featureKey, periodType, periodStart])
  @@index([companyId])
  @@index([featureKey])
  @@index([periodType])
  @@index([periodStart])
  @@index([periodEnd])
}

model FeatureUsageEvent {
  id String @id @default(cuid())

  companyId String
  counterId String

  featureKey FeatureEntitlementKey

  type   FeatureUsageEventType
  status FeatureUsageEventStatus @default(APPLIED)

  amount Int

  beforeCount Int
  afterCount  Int

  idempotencyKey String?

  reason   String?
  metadata Json?

  company Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  counter FeatureUsageCounter @relation(fields: [counterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([companyId, featureKey, idempotencyKey])
  @@index([companyId])
  @@index([counterId])
  @@index([featureKey])
  @@index([status])
  @@index([createdAt])
}

model UsageQuotaAlert {
  id String @id @default(cuid())

  companyId String
  counterId String

  featureKey FeatureEntitlementKey

  thresholdPercent Int
  usedCount        Int
  limitValue       Int
  percentage       Float

  severity UsageQuotaAlertSeverity
  status   UsageQuotaAlertStatus   @default(ACTIVE)

  message String

  acknowledgedAt DateTime?
  resolvedAt     DateTime?

  metadata Json?

  company Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  counter FeatureUsageCounter @relation(fields: [counterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, counterId, thresholdPercent])
  @@index([companyId])
  @@index([counterId])
  @@index([featureKey])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

model PlanCheckout {
  id String @id @default(cuid())

  companyId         String
  requestedByUserId String?

  fromPlan BillingPlan
  toPlan   BillingPlan

  status PlanCheckoutStatus @default(CREATED)

  amountPaise Int
  currency    String @default("INR")

  cashfreeOrderId   String?
  cashfreePaymentId String?
  cashfreeSignature String?

  paidAt   DateTime?
  failedAt DateTime?

  failureReason String?
  metadata      Json?

  expiresAt DateTime?

  webhookProcessedAt      DateTime?
  reconciliationAttempts  Int       @default(0)
  lastReconciliationAt    DateTime?
  lastReconciliationError String?

  manualReviewReason     String?
  manualReviewOpenedAt   DateTime?
  manualReviewedAt       DateTime?
  manualReviewedByUserId String?
  manualReviewDecision   BillingOpsReviewDecision?
  manualReviewNotes      String?

  reconciliationEvents PlanCheckoutReconciliationEvent[]

  company          Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requestedBy      User?   @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)
  manualReviewedBy User?   @relation("ManualReviewedPlanCheckouts", fields: [manualReviewedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([requestedByUserId])
  @@index([fromPlan])
  @@index([toPlan])
  @@index([status])
  @@index([cashfreeOrderId])
  @@index([cashfreePaymentId])
  @@index([expiresAt])
  @@index([webhookProcessedAt])
  @@index([lastReconciliationAt])
  @@index([manualReviewOpenedAt])
  @@index([manualReviewedAt])
  @@index([manualReviewedByUserId])
  @@index([manualReviewDecision])
  @@index([createdAt])
}

