model User {
  id          String  @id @default(cuid())
  clerkUserId String  @unique
  email       String  @unique
  name        String?
  mobile      String?
  imageUrl    String?

  platformRole          PlatformRole @default(NONE)
  platformAccessEnabled Boolean      @default(false)

  companies                           CompanyUser[]
  // Tenant-scoped records below must not be loaded via User include/select.
  // Query them with both companyId and userId, preferably through
  // src/server/services/tenant-user-relations.service.ts.
  assignedContacts                    Contact[]                          @relation("ContactAssignee")
  inboxNotes                          InboxNote[]                        @relation("InboxNoteAuthor")
  contactActivities                   ContactActivity[]
  inboxSavedViews                     InboxSavedView[]
  createdQuickReplies                 QuickReply[]                       @relation("QuickReplyCreator")
  sentCompanyInvites                  CompanyInvite[]                    @relation("SentCompanyInvites")
  acceptedCompanyInvites              CompanyInvite[]                    @relation("AcceptedCompanyInvites")
  auditLogs                           AuditLog[]
  createdApiKeys                      ApiKey[]
  createdBulkMessageBatches           BulkMessageBatch[]
  createdContactSegments              ContactSegment[]
  generatedContactSegmentPreviews     ContactSegmentPreview[]
  createdTemplateVariableMappings     TemplateVariableMapping[]
  createdCampaignLaunchRuns           CampaignLaunchRun[]
  generatedCampaignFailureInsightRuns CampaignFailureInsightRun[]
  fixedCampaignFailureInsights        CampaignFailureInsight[]           @relation("FixedCampaignFailureInsights")
  ignoredCampaignFailureInsights      CampaignFailureInsight[]           @relation("IgnoredCampaignFailureInsights")
  retriedCampaignFailureInsights      CampaignFailureInsight[]           @relation("RetriedCampaignFailureInsights")
  updatedCampaignThroughputPolicies   CampaignThroughputPolicy[]
  generatedCampaignCompletionReports  CampaignCompletionReport[]
  generatedCampaignReportExports      CampaignReportExport[]
  createdCampaignConversionEvents     CampaignConversionEvent[]
  assignedCampaignFollowUpTasks       CampaignFollowUpTask[]             @relation("AssignedCampaignFollowUpTasks")
  completedCampaignFollowUpTasks      CampaignFollowUpTask[]             @relation("CompletedCampaignFollowUpTasks")
  ignoredCampaignFollowUpTasks        CampaignFollowUpTask[]             @relation("IgnoredCampaignFollowUpTasks")
  companyNotificationRecipients       CompanyNotificationRecipient[]
  companyNotificationPreferences      CompanyNotificationPreference[]
  companyNotificationEmailDeliveries  CompanyNotificationEmailDelivery[]
  privacyRequests                     PrivacyRequest[]
  contactConsentEvents                ContactConsentEvent[]
  complianceEvidenceExports           ComplianceEvidenceExport[]
  trustDocumentAcceptances            TrustDocumentAcceptance[]
  accessRoleAssignments               CompanyAccessRoleAssignment[]
  createdEntitlementOverrides         CompanyEntitlementOverride[]
  entitlementCheckLogs                FeatureEntitlementCheckLog[]
  requestedPlanCheckouts              PlanCheckout[]
  companyPlanChanges                  CompanyPlanChange[]
  billingInvoices                     BillingInvoice[]
  requestedScheduledPlanChanges       ScheduledPlanChange[]
  manualReviewedPlanCheckouts         PlanCheckout[]                     @relation("ManualReviewedPlanCheckouts")
  requestedBillingRefunds             BillingRefund[]
  updatedBillingProfiles              CompanyBillingProfile[]            @relation("BillingProfileUpdatedBy")
  billingProfileUpdateEvents          BillingProfileUpdateEvent[]
  contactImportJobs                   ContactImportJob[]
  workspacePreference                 UserWorkspacePreference?
  platformCompanyActionLogs           PlatformCompanyActionLog[]
  platformCompanyNotes                PlatformCompanyNote[]
  assignedCompanyPlans                CompanyPlanAssignment[]            @relation("AssignedCompanyPlans")
  companyPlanAssignmentEvents         CompanyPlanAssignmentEvent[]       @relation("CompanyPlanAssignmentEventActor")
  whatsAppEmbeddedSignupEvents        WhatsAppEmbeddedSignupEvent[]
  createdChatbots                     Chatbot[]                          @relation("ChatbotCreator")
  updatedChatbots                     Chatbot[]                          @relation("ChatbotUpdater")
  createdChatbotVersions              ChatbotVersion[]                   @relation("ChatbotVersionCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id   String @id @default(cuid())
  name String

  type   CompanyType   @default(DIRECT_COMPANY)
  status CompanyStatus @default(PENDING_ONBOARDING)

  parentCompanyId String?
  parentCompany   Company?  @relation("PartnerChildCompanies", fields: [parentCompanyId], references: [id], onDelete: SetNull)
  childCompanies  Company[] @relation("PartnerChildCompanies")

  billingOwnerType CompanyBillingOwnerType @default(SELF)

  legalName        String?
  brandName        String?
  industry         String?
  website          String?
  businessCategory String?
  city             String?
  pinCode          String?
  channelPartner   String?
  employeeCode     String?

  whatsappUpdatesConsent   Boolean   @default(false)
  whatsappUpdatesConsentAt DateTime?

  supportEmail String?
  supportPhone String?

  isSandbox             Boolean   @default(false)
  onboardingCompletedAt DateTime?
  suspendedAt           DateTime?
  suspensionReason      String?

  platformNotes String?

  metaPaymentMethodAdded         Boolean   @default(false)
  metaBusinessVerificationStatus String    @default("NOT_STARTED")
  productionChecklistNotes       String?
  productionChecklistUpdatedAt   DateTime?

  billingPlan            BillingPlan        @default(FREE)
  subscriptionStatus     SubscriptionStatus @default(TRIALING)
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  monthlyMessageLimit    Int                @default(100)
  cancelAtPeriodEnd      Boolean            @default(false)
  subscriptionCanceledAt DateTime?

  users                             CompanyUser[]
  whatsAppAccounts                  WhatsAppAccount[]
  whatsAppPhoneNumbers              WhatsAppPhoneNumber[]
  whatsAppEmbeddedSignupEvents      WhatsAppEmbeddedSignupEvent[]
  whatsAppFlows                     WhatsAppFlow[]
  whatsAppFlowResponses             WhatsAppFlowResponse[]
  chatbots                          Chatbot[]
  chatbotVersions                   ChatbotVersion[]
  chatbotNodes                      ChatbotNode[]
  chatbotEdges                      ChatbotEdge[]
  chatbotTriggers                   ChatbotTrigger[]
  chatbotSessions                   ChatbotSession[]
  chatbotSessionEvents              ChatbotSessionEvent[]
  contactImportJobs                 ContactImportJob[]
  contactImportRows                 ContactImportRow[]
  templates                         Template[]
  contacts                          Contact[]
  messages                          Message[]
  messageEvents                     MessageEvent[]
  webhookEvents                     WebhookEvent[]
  resolvedUnmappedWebhookEvents     UnmappedWebhookEvent[]
  campaigns                         Campaign[]
  campaignContacts                  CampaignContact[]
  wallet                            Wallet?
  leadScoringConfig                 LeadScoringConfig?
  walletTransactions                WalletTransaction[]
  invites                           CompanyInvite[]
  auditLogs                         AuditLog[]
  inboxNotes                        InboxNote[]
  inboxTags                         InboxTag[]
  contactInboxTags                  ContactInboxTag[]
  contactActivities                 ContactActivity[]
  inboxSavedViews                   InboxSavedView[]
  campaignAnalyticsSnapshots        CampaignAnalyticsSnapshot[]
  campaignReplyAttributions         CampaignReplyAttribution[]
  quickReplies                      QuickReply[]
