model UserWorkspacePreference {
  id String @id @default(cuid())

  userId          String  @unique
  activeCompanyId String?

  lastSelectedAt DateTime?

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeCompany Company? @relation("ActiveCompanyPreference", fields: [activeCompanyId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([activeCompanyId])
  @@index([lastSelectedAt])
}

model CompanyUser {
  id String @id @default(cuid())

  userId    String
  companyId String
  role      CompanyRole @default(MEMBER)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, companyId])
}

model InboxQueue {
  id               String              @id @default(cuid())
  companyId        String
  name             String
  slug             String
  description      String?
  color            String?
  status           InboxQueueStatus    @default(ACTIVE)
  assignmentMode   InboxAssignmentMode @default(MANUAL)
  fallbackQueueId  String?
  maxOpenPerAgent  Int?
  approvalRequired Boolean             @default(false)

  company          Company                       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fallbackQueue    InboxQueue?                   @relation("InboxQueueFallback", fields: [fallbackQueueId], references: [id], onDelete: SetNull)
  fallbackFor      InboxQueue[]                  @relation("InboxQueueFallback")
  members          InboxQueueMember[]
  requiredSkills   InboxQueueRequiredSkill[]
  contacts         Contact[]
  assignments      InboxConversationAssignment[]
  routingRules     InboxRoutingRule[]            @relation("InboxRoutingRuleTargetQueue")
  fallbackRules    InboxRoutingRule[]            @relation("InboxRoutingRuleFallbackQueue")
  quickReplies     QuickReply[]
  replyApprovals   InboxReplyApproval[]
  businessHours    InboxBusinessHours[]
  slaPolicies      InboxSlaPolicy[]
  slaEvents        InboxSlaEvent[]
  escalationRules  InboxEscalationRule[]
  agentMetricDaily InboxAgentMetricDaily[]
  csatSurveys      InboxCsatSurvey[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, slug])
  @@index([companyId, status])
  @@index([fallbackQueueId])
}

model InboxQueueMember {
  id              String               @id @default(cuid())
  companyId       String
  queueId         String
  userId          String
  role            InboxQueueMemberRole @default(AGENT)
  acceptingNew    Boolean              @default(true)
  maxOpenOverride Int?
  sortOrder       Int                  @default(0)
  joinedAt        DateTime             @default(now())

  company Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  queue   InboxQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  user    User       @relation("InboxQueueMemberUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([queueId, userId])
  @@index([companyId])
  @@index([userId])
}

model InboxAgentProfile {
  id                   String                       @id @default(cuid())
  companyId            String
  userId               String
  availabilityStatus   InboxAgentAvailabilityStatus @default(OFFLINE)
  acceptingNew         Boolean                      @default(true)
  maxOpenConversations Int                          @default(25)
  preferredLanguage    String?
  timezone             String                       @default("Asia/Kolkata")
  lastAssignedAt       DateTime?
  lastSeenAt           DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation("InboxAgentProfileUser", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, userId])
  @@index([companyId, availabilityStatus])
  @@index([userId])
}

model InboxAgentMetricDaily {
  id String @id @default(cuid())

  companyId String
  userId    String
  queueId   String?
  date      DateTime

  assignedCount           Int  @default(0)
  replyCount              Int  @default(0)
  resolvedCount           Int  @default(0)
  reopenedCount           Int  @default(0)
  averageFirstResponseSec Int?
  p50FirstResponseSec     Int?
  p90FirstResponseSec     Int?
  averageResolutionSec    Int?
  slaMetCount             Int  @default(0)
  slaBreachedCount        Int  @default(0)
  csatScoreSum            Int  @default(0)
  csatResponseCount       Int  @default(0)
  availableSeconds        Int  @default(0)
  busySeconds             Int  @default(0)

  company Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User        @relation("InboxAgentMetricDailyUser", fields: [userId], references: [id], onDelete: Cascade)
  queue   InboxQueue? @relation(fields: [queueId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, userId, queueId, date])
  @@index([companyId, date])
  @@index([userId, date])
  @@index([queueId, date])
}

model InboxCsatSurvey {
  id               String    @id @default(cuid())
  companyId        String
  contactId        String
  queueId          String?
  assignedToUserId String?
  closedByUserId   String?
  status           String    @default("PENDING")
  sentMessageId    String?
  score            Int?
  comment          String?
  sentAt           DateTime?
  respondedAt      DateTime?
  expiresAt        DateTime?
  closeCycleKey    String

  company        Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact        Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  queue          InboxQueue? @relation(fields: [queueId], references: [id], onDelete: SetNull)
  assignedToUser User?       @relation("InboxCsatAssignedAgent", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  closedByUser   User?       @relation("InboxCsatClosedBy", fields: [closedByUserId], references: [id], onDelete: SetNull)
  sentMessage    Message?    @relation("InboxCsatSentMessage", fields: [sentMessageId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, contactId, closeCycleKey])
  @@index([companyId, status])
  @@index([companyId, respondedAt])
  @@index([companyId, assignedToUserId])
  @@index([companyId, queueId])
  @@index([contactId])
  @@index([sentMessageId])
}

model InboxSkill {
  id          String  @id @default(cuid())
  companyId   String
  name        String
  slug        String
  description String?

  company          Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agentSkills      InboxAgentSkill[]
  requiredByQueues InboxQueueRequiredSkill[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, slug])
  @@index([companyId])
}

model InboxAgentSkill {
  id        String @id @default(cuid())
  companyId String
  userId    String
  skillId   String
  level     Int    @default(1)

  company Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User       @relation("InboxAgentSkillUser", fields: [userId], references: [id], onDelete: Cascade)
  skill   InboxSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@index([companyId])
  @@index([skillId])
}

model InboxQueueRequiredSkill {
  id           String @id @default(cuid())
  companyId    String
  queueId      String
  skillId      String
  minimumLevel Int    @default(1)

  company Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  queue   InboxQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  skill   InboxSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([queueId, skillId])
  @@index([companyId])
  @@index([skillId])
}

model InboxBusinessHours {
  id        String  @id @default(cuid())
  companyId String
  queueId   String?
  name      String  @default("Default business hours")
  timezone  String  @default("Asia/Kolkata")
  active    Boolean @default(true)

  company Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  queue   InboxQueue?                @relation(fields: [queueId], references: [id], onDelete: Cascade)
  windows InboxBusinessHoursWindow[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, active])
  @@index([queueId])
}

model InboxBusinessHoursWindow {
  id              String  @id @default(cuid())
  businessHoursId String
  dayOfWeek       Int
  startMinute     Int
  endMinute       Int
  active          Boolean @default(true)

  businessHours InboxBusinessHours @relation(fields: [businessHoursId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessHoursId, dayOfWeek])
}

model InboxHoliday {
  id        String   @id @default(cuid())
  companyId String
  name      String
  date      DateTime
  timezone  String   @default("Asia/Kolkata")
  active    Boolean  @default(true)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, date])
  @@index([companyId, active])
}

model InboxSlaPolicy {
  id                   String        @id @default(cuid())
  companyId            String
  queueId              String?
  priority             InboxPriority @default(NORMAL)
  firstResponseMinutes Int           @default(240)
  nextResponseMinutes  Int           @default(240)
  resolutionMinutes    Int           @default(1440)
  dueSoonMinutes       Int           @default(30)
  pauseWhileSnoozed    Boolean       @default(true)
  active               Boolean       @default(true)

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  queue   InboxQueue?     @relation(fields: [queueId], references: [id], onDelete: Cascade)
  events  InboxSlaEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, queueId, priority])
  @@index([companyId, active])
  @@index([queueId])
}

model InboxSlaEvent {
  id          String            @id @default(cuid())
  companyId   String
  contactId   String
  queueId     String?
  policyId    String?
  actorUserId String?
  type        InboxSlaEventType
  dueAt       DateTime?
  occurredAt  DateTime          @default(now())
  metadata    Json?

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  queue   InboxQueue?     @relation(fields: [queueId], references: [id], onDelete: SetNull)
  policy  InboxSlaPolicy? @relation(fields: [policyId], references: [id], onDelete: SetNull)
  actor   User?           @relation("InboxSlaEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([companyId, type, occurredAt])
  @@index([contactId, occurredAt])
  @@index([queueId])
  @@index([policyId])
}

model InboxEscalationRule {
  id           String                     @id @default(cuid())
  companyId    String
  queueId      String?
  name         String
  priority     InboxPriority?
  triggerType  InboxEscalationTriggerType
  triggerValue Int                        @default(1)
  actions      Json
  active       Boolean                    @default(true)

  company Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  queue   InboxQueue? @relation(fields: [queueId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, active])
  @@index([queueId])
  @@index([companyId, triggerType])
}

model InboxConversationAssignment {
  id               String                @id @default(cuid())
  companyId        String
  contactId        String
  queueId          String?
  assignedToUserId String?
  previousQueueId  String?
  previousUserId   String?
  source           InboxAssignmentSource
  ruleId           String?
  actorUserId      String?
  reason           String?
  metadata         Json?
  assignedAt       DateTime              @default(now())
  unassignedAt     DateTime?

  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact        Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  queue          InboxQueue?       @relation(fields: [queueId], references: [id], onDelete: SetNull)
  assignedToUser User?             @relation("InboxConversationAssignedUser", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  actorUser      User?             @relation("InboxConversationAssignmentActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  rule           InboxRoutingRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

