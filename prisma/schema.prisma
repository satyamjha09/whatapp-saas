  planChangeId     String?

  reconciliationAttempts  Int                                @default(0)
  lastReconciliationAt    DateTime?
  lastReconciliationError String?
  webhookProcessedAt      DateTime?
  reconciliationEvents    BillingRefundReconciliationEvent[]

  metadata Json?

  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice     BillingInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  requestedBy User?           @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)

  creditNote      BillingCreditNote?
  emailDeliveries BillingDocumentEmailDelivery[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([invoiceId])
  @@index([checkoutId])
  @@index([requestedByUserId])
  @@index([status])
  @@index([type])
  @@index([cashfreePaymentId])
  @@index([cashfreeRefundId])
  @@index([createdAt])
  @@index([lastReconciliationAt])
  @@index([webhookProcessedAt])
}

model BillingCreditNote {
