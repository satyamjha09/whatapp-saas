generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CompanyRole {
  OWNER
  ADMIN
  MEMBER
}

enum CompanyInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum BillingPlan {
  FREE
  STARTER
  GROWTH
  BUSINESS
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum CompanyNotificationType {
  BILLING
  WALLET
  WEBHOOK
  DEVELOPER_API
  CAMPAIGN
  SYSTEM
}

enum CompanyNotificationSeverity {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum CompanyNotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum CompanyNotificationEmailDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum WhatsAppAccountStatus {
  PENDING
  CONNECTED
  DISCONNECTED
  ERROR
}

enum TemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

enum TemplateStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PAUSED
  IN_APPEAL
  PENDING_DELETION
  DELETED
  DISABLED
  LIMIT_EXCEEDED
}

enum MessageStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
  RECEIVED
  CANCELED
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum InboxConversationStatus {
  OPEN
  CLOSED
}

enum InboxPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ContactActivityType {
  MESSAGE_INBOUND
  MESSAGE_OUTBOUND
  NOTE_CREATED
  NOTE_UPDATED
  NOTE_DELETED
  ASSIGNED
  UNASSIGNED
  STATUS_CHANGED
  PRIORITY_CHANGED
  TAG_ADDED
  TAG_REMOVED
  SNOOZED
  UNSNOOZED
  BLOCKED
  UNBLOCKED
  OPTED_OUT
  OPTED_IN
  PROFILE_UPDATED
}

enum InboxSavedViewVisibility {
  PRIVATE
  COMPANY
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum CampaignContactStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  SKIPPED
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  REFUND
  ADJUSTMENT
}

enum WalletTransactionStatus {
  PENDING
  SUCCESS
  FAILED
  COMPLETED
  REFUNDED
}

enum CreditPurchaseStatus {
  CREATED
  PAID
  FAILED
}

enum SubscriptionPaymentStatus {
  CREATED
  PAID
  FAILED
}

enum RazorpayWebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
  IGNORED
}

enum MaintenanceJobRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum DatabaseBackupStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum DatabaseBackupVerificationStatus {
  NOT_VERIFIED
  VERIFIED
  FAILED
}

enum ProviderWebhookProvider {
  META
  RAZORPAY
}

enum ProviderWebhookEventStatus {
  PROCESSING
  SUCCEEDED
  FAILED
  SKIPPED_DUPLICATE
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum IncidentSource {
  SYSTEM
  SECURITY
  WORKER
  BACKUP
  WEBHOOK
  BILLING
  DEPLOYMENT
  DATABASE_RESTORE
  PLATFORM
}

enum IncidentTimelineType {
  CREATED
  ACKNOWLEDGED
  RESOLVED
  REOPENED
  COMMENT
  SYSTEM_UPDATE
}

enum DeadLetterJobStatus {
  FAILED
  RETRIED
  IGNORED
  RESOLVED
}

enum MessageUsageLedgerStatus {
  CHARGED
}

enum BillingReconciliationRunStatus {
  RUNNING
  PASSED
  FAILED
}

enum BillingReconciliationIssueType {
  WALLET_BALANCE_MISMATCH
  MISSING_WALLET_TRANSACTION
  WALLET_TRANSACTION_AMOUNT_MISMATCH
  DUPLICATE_MESSAGE_CHARGE
  ORPHAN_USAGE_LEDGER
  ORPHAN_WALLET_TRANSACTION
}

enum BillingReconciliationIssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PublicApiIdempotencyStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum SystemWorkerHeartbeatStatus {
  RUNNING
  STOPPED
  ERROR
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

enum DeveloperWebhookEndpointStatus {
  ACTIVE
  REVOKED
  AUTO_DISABLED
}

enum DeveloperWebhookDeliveryStatus {
  PENDING
  SENDING
  DELIVERED
  FAILED
}

enum DeveloperWebhookOutboxStatus {
  PENDING
  PROCESSING
  DELIVERED
  FAILED
}

enum DeveloperApiRequestLogStatus {
  SUCCESS
  FAILED
  BLOCKED
  RATE_LIMITED
}

enum BulkMessageBatchStatus {
  SCHEDULED
  QUEUED
  PARTIAL_FAILED
  FAILED
  CANCELED
}

enum BulkMessageRecipientStatus {
  SCHEDULED
  QUEUED
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
  SKIPPED_DUPLICATE
  SKIPPED_BLOCKED
  CANCELED
}

model User {
  id          String  @id @default(cuid())
  clerkUserId String  @unique
  email       String  @unique
  name        String?
  imageUrl    String?

  companies                          CompanyUser[]
  assignedContacts                   Contact[]                          @relation("ContactAssignee")
  inboxNotes                         InboxNote[]                        @relation("InboxNoteAuthor")
  contactActivities                  ContactActivity[]
  inboxSavedViews                    InboxSavedView[]
  createdQuickReplies                QuickReply[]                       @relation("QuickReplyCreator")
  sentCompanyInvites                 CompanyInvite[]                    @relation("SentCompanyInvites")
  acceptedCompanyInvites             CompanyInvite[]                    @relation("AcceptedCompanyInvites")
  auditLogs                          AuditLog[]
  createdApiKeys                     ApiKey[]
  createdBulkMessageBatches          BulkMessageBatch[]
  companyNotificationRecipients      CompanyNotificationRecipient[]
  companyNotificationPreferences     CompanyNotificationPreference[]
  companyNotificationEmailDeliveries CompanyNotificationEmailDelivery[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id   String @id @default(cuid())
  name String

  metaPaymentMethodAdded         Boolean   @default(false)
  metaBusinessVerificationStatus String    @default("NOT_STARTED")
  productionChecklistNotes       String?
  productionChecklistUpdatedAt   DateTime?

  billingPlan            BillingPlan        @default(FREE)
  subscriptionStatus     SubscriptionStatus @default(TRIALING)
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  monthlyMessageLimit    Int                @default(100)
  cancelAtPeriodEnd      Boolean            @default(false)
  subscriptionCanceledAt DateTime?

  users                       CompanyUser[]
  whatsAppAccounts            WhatsAppAccount[]
  whatsAppPhoneNumbers        WhatsAppPhoneNumber[]
  templates                   Template[]
  contacts                    Contact[]
  messages                    Message[]
  messageEvents               MessageEvent[]
  webhookEvents               WebhookEvent[]
  campaigns                   Campaign[]
  campaignContacts            CampaignContact[]
  wallet                      Wallet?
  walletTransactions          WalletTransaction[]
  invites                     CompanyInvite[]
  auditLogs                   AuditLog[]
  inboxNotes                  InboxNote[]
  inboxTags                   InboxTag[]
  contactInboxTags            ContactInboxTag[]
  contactActivities           ContactActivity[]
  inboxSavedViews             InboxSavedView[]
  quickReplies                QuickReply[]
  apiKeys                     ApiKey[]
  developerWebhookEndpoints   DeveloperWebhookEndpoint[]
  developerWebhookDeliveries  DeveloperWebhookDelivery[]
  developerWebhookOutbox      DeveloperWebhookOutbox[]
  bulkMessageBatches          BulkMessageBatch[]
  contactGroups               ContactGroup[]
  creditPurchases             CreditPurchase[]
  subscriptionPayments        SubscriptionPayment[]
  razorpayWebhookEvents       RazorpayWebhookEvent[]
  maintenanceJobRuns          MaintenanceJobRun[]
  developerApiUsage           DeveloperApiUsage[]
  developerApiRequestLogs     DeveloperApiRequestLog[]
  publicApiIdempotencyRecords PublicApiIdempotencyRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyUser {
  id String @id @default(cuid())

  userId    String
  companyId String
  role      CompanyRole @default(MEMBER)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, companyId])
}

model CompanyNotification {
  id             String                      @id @default(cuid())
  companyId      String
  type           CompanyNotificationType
  severity       CompanyNotificationSeverity @default(INFO)
  status         CompanyNotificationStatus   @default(UNREAD)
  title          String
  message        String
  actionHref     String?
  idempotencyKey String?
  metadata       Json?
  readAt         DateTime?
  archivedAt     DateTime?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  recipients      CompanyNotificationRecipient[]
  emailDeliveries CompanyNotificationEmailDelivery[]

  @@unique([companyId, idempotencyKey])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, type])
  @@index([createdAt])
}

model CompanyNotificationRecipient {
  id             String                    @id @default(cuid())
  notificationId String
  userId         String
  status         CompanyNotificationStatus @default(UNREAD)
  readAt         DateTime?
  archivedAt     DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  notification CompanyNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([notificationId])
  @@index([userId])
  @@index([userId, status])
}

model CompanyNotificationPreference {
  id                   String                      @id @default(cuid())
  companyId            String
  userId               String
  type                 CompanyNotificationType
  inAppEnabled         Boolean                     @default(true)
  minimumSeverity      CompanyNotificationSeverity @default(INFO)
  emailEnabled         Boolean                     @default(false)
  emailMinimumSeverity CompanyNotificationSeverity @default(ERROR)
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, type])
  @@index([companyId])
  @@index([userId])
}

model CompanyNotificationEmailDelivery {
  id             String                                 @id @default(cuid())
  companyId      String
  notificationId String
  userId         String
  toEmail        String
  subject        String
  actionUrl      String?
  status         CompanyNotificationEmailDeliveryStatus @default(PENDING)
  attempts       Int                                    @default(0)
  lastError      String?
  sentAt         DateTime?
  skippedAt      DateTime?
  createdAt      DateTime                               @default(now())
  updatedAt      DateTime                               @updatedAt

  notification CompanyNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([companyId])
  @@index([notificationId])
  @@index([userId])
  @@index([status])
}

model WhatsAppAccount {
  id        String @id @default(cuid())
  companyId String

  wabaId                 String?               @unique
  businessName           String?
  accessToken            String?
  accessTokenKeyId       String?
  accessTokenEncryptedAt DateTime?
  status                 WhatsAppAccountStatus @default(PENDING)

  company      Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  phoneNumbers WhatsAppPhoneNumber[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([accessTokenKeyId])
}

model WhatsAppPhoneNumber {
  id                String @id @default(cuid())
  companyId         String
  whatsAppAccountId String

  phoneNumberId      String? @unique
  displayPhoneNumber String?
  verifiedName       String?
  qualityRating      String?

  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  whatsAppAccount WhatsAppAccount @relation(fields: [whatsAppAccountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([whatsAppAccountId])
}

model Template {
  id        String @id @default(cuid())
  companyId String

  name     String
  language String
  category TemplateCategory
  status   TemplateStatus   @default(DRAFT)

  body       String
  variables  String[]
  components Json?

  metaTemplateId String?

  company            Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messages           Message[]
  campaigns          Campaign[]
  bulkMessageBatches BulkMessageBatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name, language])
  @@index([companyId])
}

model Contact {
  id               String  @id @default(cuid())
  companyId        String
  assignedToUserId String?

  name                 String?
  email                String?
  companyName          String?
  phoneNumber          String
  countryCode          String    @default("91")
  source               String    @default("MANUAL")
  externalCustomerId   String?
  lifecycleStage       String    @default("LEAD")
  lastSeenAt           DateTime?
  lastRepliedAt        DateTime?
  lastProfileUpdatedAt DateTime?
  isBlocked            Boolean   @default(false)
  blockedAt            DateTime?
  optedOutAt           DateTime?
  optOutReason         String?
  optOutSource         String?

  inboxStatus                InboxConversationStatus @default(OPEN)
  inboxClosedAt              DateTime?
  inboxPriority              InboxPriority           @default(NORMAL)
  snoozedUntil               DateTime?
  inboxSlaDueAt              DateTime?
  inboxLastCustomerMessageAt DateTime?
  inboxSlaBreachedAt         DateTime?
  inboxSlaEscalationCount    Int                     @default(0)

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedTo          User?                @relation("ContactAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  messages            Message[]
  inboxNotes          InboxNote[]
  inboxTags           ContactInboxTag[]
  activities          ContactActivity[]
  campaignContacts    CampaignContact[]
  contactGroupMembers ContactGroupMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, phoneNumber])
  @@index([companyId])
  @@index([assignedToUserId])
  @@index([companyId, inboxStatus])
  @@index([companyId, inboxPriority])
  @@index([companyId, snoozedUntil])
  @@index([companyId, inboxSlaDueAt])
  @@index([companyId, inboxStatus, inboxSlaDueAt])
  @@index([companyId, inboxSlaBreachedAt])
  @@index([companyId, inboxStatus, inboxSlaDueAt, inboxSlaBreachedAt])
  @@index([companyId, optedOutAt])
  @@index([companyId, lifecycleStage])
  @@index([companyId, externalCustomerId])
  @@index([lastSeenAt])
  @@index([lastRepliedAt])
}

model ContactActivity {
  id String @id @default(cuid())

  companyId String
  contactId String

  actorUserId String?

  type        ContactActivityType
  title       String
  description String?
  metadata    Json?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  actor   User?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([contactId])
  @@index([actorUserId])
  @@index([type])
  @@index([createdAt])
}

model InboxSavedView {
  id String @id @default(cuid())

  companyId String
  userId    String?

  name       String
  visibility InboxSavedViewVisibility @default(PRIVATE)

  filters Json
  sortBy  String @default("recent")

  isDefault Boolean @default(false)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([userId])
  @@index([visibility])
  @@index([isDefault])
}

model ContactGroup {
  id          String  @id @default(cuid())
  companyId   String
  name        String
  description String?
  color       String?

  company Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  members ContactGroupMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model ContactGroupMember {
  id        String @id @default(cuid())
  groupId   String
  contactId String

  group   ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  contact Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([groupId, contactId])
  @@index([groupId])
  @@index([contactId])
}

model InboxNote {
  id        String @id @default(cuid())
  companyId String
  contactId String

  authorUserId String

  body String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  author  User    @relation("InboxNoteAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, contactId])
  @@index([authorUserId])
}

model InboxTag {
  id        String @id @default(cuid())
  companyId String

  name  String
  color String @default("gray")

  company  Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contacts ContactInboxTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model ContactInboxTag {
  id        String @id @default(cuid())
  companyId String
  contactId String
  tagId     String

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     InboxTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([contactId, tagId])
  @@index([companyId])
  @@index([companyId, tagId])
}

model QuickReply {
  id        String @id @default(cuid())
  companyId String

  title String
  body  String

  createdByUserId String?

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("QuickReplyCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, title])
  @@index([companyId])
  @@index([createdByUserId])
}

model Message {
  id        String @id @default(cuid())
  companyId String

  contactId         String
  templateId        String?
  campaignId        String?
  campaignContactId String? @unique

  direction MessageDirection @default(OUTBOUND)
  status    MessageStatus    @default(QUEUED)

  toPhoneNumber String
  body          String
  variables     String[]

  metaMessageId String?

  inboxReadAt DateTime?

  company                   Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact                   Contact                    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  template                  Template?                  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  campaign                  Campaign?                  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  campaignContact           CampaignContact?           @relation(fields: [campaignContactId], references: [id], onDelete: SetNull)
  bulkMessageBatchRecipient BulkMessageBatchRecipient?

  events       MessageEvent[]
  usageLedgers MessageUsageLedger[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([contactId])
  @@index([templateId])
  @@index([metaMessageId])
  @@index([campaignId])
  @@index([campaignContactId])
  @@index([companyId, direction, inboxReadAt])
}

model MessageEvent {
  id        String @id @default(cuid())
  companyId String
  messageId String

  status MessageStatus
  raw    Json?

  dedupeKey String? @unique

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([messageId])
}

model WebhookEvent {
  id        String  @id @default(cuid())
  companyId String?

  source String             @default("whatsapp")
  status WebhookEventStatus @default(RECEIVED)

  eventType String?
  payload   Json

  dedupeKey String? @unique

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([status])
  @@index([eventType])
}

model Campaign {
  id         String @id @default(cuid())
  companyId  String
  templateId String

  name   String
  status CampaignStatus @default(DRAFT)

  variables String[]

  totalContacts  Int @default(0)
  queuedCount    Int @default(0)
  sentCount      Int @default(0)
  deliveredCount Int @default(0)
  readCount      Int @default(0)
  failedCount    Int @default(0)

  scheduledAt DateTime?

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  contacts CampaignContact[]
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([templateId])
  @@index([status])
}

model CampaignContact {
  id         String @id @default(cuid())
  companyId  String
  campaignId String
  contactId  String

  status    CampaignContactStatus @default(PENDING)
  variables String[]

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  message Message?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, contactId])
  @@index([companyId])
  @@index([campaignId])
  @@index([contactId])
  @@index([status])
}

model BulkMessageBatch {
  id              String  @id @default(cuid())
  companyId       String
  templateId      String?
  createdByUserId String?

  templateName          String?
  contactGroupId        String?
  contactGroupName      String?
  status                BulkMessageBatchStatus @default(QUEUED)
  requestedCount        Int                    @default(0)
  queuedCount           Int                    @default(0)
  failedCount           Int                    @default(0)
  skippedDuplicateCount Int                    @default(0)
  skippedBlockedCount   Int                    @default(0)
  scheduledAt           DateTime?
  canceledAt            DateTime?

  company    Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  template   Template?                   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdBy  User?                       @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  recipients BulkMessageBatchRecipient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([templateId])
  @@index([contactGroupId])
  @@index([createdByUserId])
  @@index([createdAt])
}

model BulkMessageBatchRecipient {
  id         String  @id @default(cuid())
  batchId    String
  messageId  String? @unique
  queueJobId String?

  countryCode    String
  phoneNumber    String
  name           String?
  bodyParameters Json?
  status         BulkMessageRecipientStatus @default(QUEUED)
  errorMessage   String?

  batch   BulkMessageBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  message Message?         @relation(fields: [messageId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId])
  @@index([messageId])
  @@index([queueJobId])
  @@index([phoneNumber])
}

model Wallet {
  id        String @id @default(cuid())
  companyId String @unique

  balancePaise Int @default(0)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WalletTransaction {
  id        String @id @default(cuid())
  companyId String

  type   WalletTransactionType
  status WalletTransactionStatus @default(SUCCESS)

  amountPaise       Int
  balanceAfterPaise Int?
  description       String?

