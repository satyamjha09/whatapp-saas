model Message {
  id        String @id @default(cuid())
  companyId String

  contactId         String
  templateId        String?
  campaignId        String?
  campaignContactId String? @unique

  direction MessageDirection @default(OUTBOUND)
  status    MessageStatus    @default(QUEUED)

  toPhoneNumber String
  body          String
  variables     String[]

  metaMessageId String?
  errorCode     String?
  errorMessage  String?
  metadata      Json?

  inboxReadAt DateTime?
  queuedAt    DateTime?
  scheduledAt DateTime?

  company                   Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact                   Contact                    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  template                  Template?                  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  campaign                  Campaign?                  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  campaignContact           CampaignContact?           @relation(fields: [campaignContactId], references: [id], onDelete: SetNull)
  bulkMessageBatchRecipient BulkMessageBatchRecipient?

  events                            MessageEvent[]
  usageLedgers                      MessageUsageLedger[]
  campaignReplyAttributions         CampaignReplyAttribution[]  @relation("CampaignReplyInboundMessage")
  outboundCampaignReplyAttributions CampaignReplyAttribution[]  @relation("CampaignReplyOutboundMessage")
  campaignConversionEvents          CampaignConversionEvent[]
  campaignSequenceExecutions        CampaignSequenceExecution[] @relation("CampaignSequenceMessage")
  nextCampaignSequenceExecutions    CampaignSequenceExecution[] @relation("CampaignSequencePreviousMessage")
  whatsAppFlowResponses             WhatsAppFlowResponse[]
  chatbotSessionEvents              ChatbotSessionEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([contactId])
  @@index([templateId])
  @@index([metaMessageId])
  @@index([errorCode])
  @@index([campaignId])
  @@index([campaignContactId])
  @@index([companyId, direction, inboxReadAt])
  @@index([companyId, scheduledAt])
}

model MessageEvent {
  id        String @id @default(cuid())
