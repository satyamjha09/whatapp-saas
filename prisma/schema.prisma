  refund          BillingRefund                  @relation(fields: [refundId], references: [id], onDelete: Cascade)
  invoice         BillingInvoice?                @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  emailDeliveries BillingDocumentEmailDelivery[]
  pdfRenders      BillingDocumentPdfRender[]

