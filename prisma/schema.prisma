  method         String @default("GET")
  expectedStatus Int    @default(200)
  timeoutMs      Int    @default(10000)

  intervalMinutes Int @default(5)

  status UptimeMonitorStatus @default(ACTIVE)

  failureThreshold  Int @default(3)
  recoveryThreshold Int @default(2)

  consecutiveFailures  Int @default(0)
  consecutiveSuccesses Int @default(0)

  lastStatus     UptimeCheckStatus?
  lastStatusCode Int?
  lastLatencyMs  Int?

  lastCheckedAt DateTime?
  lastSuccessAt DateTime?
  lastFailureAt DateTime?

  openIncidentState UptimeIncidentState?
  openIncidentId    String?

  metadata Json?

  checks UptimeCheck[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([lastStatus])
  @@index([lastCheckedAt])
  @@index([openIncidentState])
}

model UptimeCheck {
  id String @id @default(cuid())

  monitorId String

  status     UptimeCheckStatus
  statusCode Int?
  latencyMs  Int?

  errorMessage    String?
  responseSnippet String?

  checkedAt DateTime @default(now())

  monitor UptimeMonitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([monitorId])
  @@index([status])
  @@index([checkedAt])
}

enum StatusPageVisibility {
