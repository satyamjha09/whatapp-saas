  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([requestedByUserId])
  @@index([type])
  @@index([status])
  @@index([fromPlan])
  @@index([toPlan])
  @@index([scheduledFor])
  @@index([createdAt])
}

model BillingInvoice {
  id String @id @default(cuid())

  companyId String
  userId    String?

  invoiceNumber String @unique

  status BillingInvoiceStatus @default(DRAFT)

  currency String @default("INR")

  subtotalPaise Int @default(0)
  taxPaise      Int @default(0)
  totalPaise    Int @default(0)

  taxBasisPoints Int @default(0)

  billingName    String?
  billingEmail   String?
  billingAddress String?
  billingTaxId   String?

  sellerName    String?
  sellerEmail   String?
  sellerAddress String?
  sellerTaxId   String?

  cashfreeOrderId   String?
  cashfreePaymentId String?

  planCheckoutId String?
  planChangeId   String?

  issuedAt DateTime?
  paidAt   DateTime?
  voidedAt DateTime?

