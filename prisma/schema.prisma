  @@index([userId])
  @@index([status])
  @@index([issuedAt])
  @@index([paidAt])
  @@index([cashfreeOrderId])
  @@index([cashfreePaymentId])
  @@index([planCheckoutId])
}

model BillingInvoiceLine {
