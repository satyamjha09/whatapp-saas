{
  "name": "whatsapp-saas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "worker:message": "tsx src/workers/message.worker.ts",
    "worker:messages": "tsx src/workers/message.worker.ts",
    "worker:bulk-message": "cross-env WORKER_HEARTBEAT_NAME=bulk-message-worker tsx src/workers/message.worker.ts",
    "worker:webhooks": "tsx src/workers/webhook.worker.ts",
    "worker:developer-webhooks": "tsx src/workers/developer-webhook.worker.ts",
    "worker:developer-webhook-outbox": "tsx src/workers/developer-webhook-outbox.worker.ts",
    "worker:inbox-sla": "tsx src/workers/inbox-sla.worker.ts",
    "worker:maintenance": "tsx src/workers/maintenance.worker.ts",
    "worker:notification-email": "tsx src/workers/notification-email.worker.ts",
    "typecheck": "tsc --noEmit",
    "prisma:check": "prisma validate",
    "check": "prisma validate && tsc --noEmit && npm run lint",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:reload": "pm2 reload ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "pm2:save": "pm2 save",
    "healthcheck": "tsx scripts/healthcheck.ts",
    "healthcheck:deep": "node -e \"fetch((process.env.NEXT_PUBLIC_APP_URL || process.env.APP_URL || 'http://localhost:3000').replace(/\\/$/, '') + '/api/health/deep', { headers: { 'x-healthcheck-token': process.env.HEALTHCHECK_TOKEN || '' } }).then(async r => { const d = await r.json(); console.log(d); process.exit(r.ok ? 0 : 1); }).catch(e => { console.error(e); process.exit(1); })\"",
    "deploy:production": "tsx scripts/production-deploy.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@clerk/nextjs": "^7.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.16.1",
    "bullmq": "^5.77.6",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.18.0",
    "next": "16.2.6",
    "nodemailer": "^9.0.1",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "pm2": "^7.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
